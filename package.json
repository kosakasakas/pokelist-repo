{
  "name": "pokelist",
  "version": "1.0.0",
  "description": "Pokelist Tools",
  "private": true,
  "scripts": {
    "postinstall": "npm --prefix library/pokemon-showdown install || (cd library/pokemon-showdown && npm install)",
    "setup": "git submodule update --init --recursive",
    "server": "http-server public -o damage-calc.html",
    "build:showdown": "npm --prefix library/pokemon-showdown run build",
    "build:data": "node scripts/export-champions-calc-data.js",
    "build:csv:ja": "node scripts/export-champions-ja-csv.js",
    "build:csv:ja-overrides": "node scripts/export-champions-ja-overrides-csv.js",
    "build:csv:ja-overrides:remaining": "node scripts/export-champions-ja-overrides-csv.js --untranslated --start-part=4 --part-count=3",
    "build:csv:ja-moves": "node scripts/export-champions-ja-missing-moves-csv.js",
    "merge:csv:ja-overrides": "node scripts/import-champions-ja-overrides-csv.js",
    "refresh:champions": "npm run build:showdown && npm run build:data && npm run build:csv:ja"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
